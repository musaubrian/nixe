[user]
	name       = musaubrian
	email      = musaubrian15@gmail.com
	signingkey = ~/.ssh/signing.pub

[gpg]
	format = ssh
[gpg "ssh"]
	allowedSignersFile = ~/.ssh/allowed_signers

[commit]
	gpgsign       = true

[init]
	defaultBranch = main

[core]
	editor        = nvim

[alias]
	status        = status -s
	dl            = log --oneline -p --ext-diff # use difft by default
	dlc           = show --ext-diff

	lg            = log --oneline --graph --decorate
	rem           = !git branch --set-upstream-to = origin/`git symbolic-ref --short HEAD`
	conflicts     = !git ls-files -u | cut -f 2 | sort -u
	track-all     = "!git branch -r | grep -v '\\->' | while read remote; do local=${remote#origin/}; git show-ref --verify --quiet refs/heads/$local || git branch --track $local $remote; done"

[pull]
	rebase          = true
[push]
	autoSetupRemote = true
	followTags      = true

[diff]
	external        = difft

[tag]
	sort            = version:refname

[column]
        ui              = auto

